// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RecommendationStatus {
  completed
  empty
}

enum ReactionType {
  liked
  too_dark
  too_long
  not_now
  mismatch
}

enum PersonRole {
  director
  actor
  writer
}

enum MovieKnownState {
  known
  unknown
}

enum SwipeAction {
  liked
  skipped
}

enum WatchedSource {
  onboarding_known
  onboarding_liked
  manual
}

enum MbtiType {
  INTJ
  INTP
  ENTJ
  ENTP
  INFJ
  INFP
  ENFJ
  ENFP
  ISTJ
  ISFJ
  ESTJ
  ESFJ
  ISTP
  ISFP
  ESTP
  ESFP
}

enum UserMood {
  want_healing
  want_to_be_moved
  want_excitement
  want_to_laugh
  want_tension
  want_quiet_immersion
  want_to_switch_off
  okay_with_something_heavy
}

enum OnboardingReactionType {
  liked
  not_for_me
  dont_know
}

enum WatchedContentType {
  movie
  drama
}

enum WatchedContentSource {
  onboarding_known
  onboarding_liked
  recommend_like
  manual
}

enum WatchedReaction {
  like
  normal
  dislike
}

enum WatchedCatalogSource {
  manual
  onboarding
  search_add
  quick_classify
  recommendation
}

enum QuickReactionAction {
  seen
  not_seen
  liked
  not_for_me
  skip
}

enum WatchSource {
  netflix
  prime_video
  cinema
  other
}

enum PreferenceInfluenceStrength {
  light
  balanced
  strong
}

enum RecommendationStyleMode {
  safe
  balanced
  discovery_focused
}

enum WatchlistSource {
  recommendation
  manual
}

model User {
  id                    String   @id @default(cuid())
  name                  String?
  username              String?  @unique
  email                 String?  @unique
  passwordHash          String?
  favoriteGenres        String[] @default([])
  excludedGenres        String[] @default([])
  preferredDirectors    String[] @default([])
  preferredActors       String[] @default([])
  preferredWriters      String[] @default([])
  metadata              Json?
  discoveryMode         String   @default("balanced")
  locale                String   @default("ja")
  useFavoritesInRecommendations Boolean @default(true)
  preferenceInfluenceStrength PreferenceInfluenceStrength @default(balanced)
  recommendationStyleMode RecommendationStyleMode @default(balanced)
  emailVerified         DateTime?
  image                 String?
  onboardingCompletedAt DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  accounts               Account[]
  sessions               Session[]
  preferences            UserPreference[]
  tasteProfiles          UserTasteProfile[]
  recommendationSessions RecommendationSession[]
  feedbackLogs           FeedbackLog[]
  onboardingProfile      UserOnboardingProfile?
  movieSwipes            UserMovieSwipe[]
  discoverSwipes         MovieSwipe[]
  movieProfile           UserMovieProfile?
  watchedMovies          UserWatchedMovie[]
  watchedContents        UserWatchedContent[]
  watchlistItems         UserWatchlistItem[]
  onboardingReactions    OnboardingMovieReaction[]
  quickReactionLogs      QuickReactionLog[]
  watchLogs              WatchLog[]
  movieLikes             MovieLike[]
  movieComments          MovieComment[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
  @@unique([token])
}

model UserPreference {
  id               String   @id @default(cuid())
  userId           String
  favoriteArtists  String[]
  favoriteMovies   String[]
  preferredMoods   String[]
  dislikedElements String[]
  inputVersion     Int      @default(1)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasteProfiles UserTasteProfile[]

  @@index([userId, createdAt(sort: Desc)])
}

model UserTasteProfile {
  id                     String   @id @default(cuid())
  userId                 String
  sourcePreferenceId     String?
  profileVersion         Int      @default(1)
  summary                String
  moodCalm               Float
  moodDark               Float
  moodEmotional          Float
  toneStylish            Float
  toneFunny              Float
  paceSlowBurn           Float
  complexity             Float
  emotionalWeight        Float
  runtimeToleranceMin    Int
  runtimeToleranceMax    Int
  metadata               Json?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  user                   User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourcePreference       UserPreference?         @relation(fields: [sourcePreferenceId], references: [id], onDelete: SetNull)
  recommendationSessions RecommendationSession[]

  @@index([userId, createdAt(sort: Desc)])
  @@index([sourcePreferenceId])
}

model Movie {
  id                   String   @id @default(cuid())
  title                String
  releaseYear          Int
  runtimeMinutes       Int
  genrePrimary         String
  genreSecondary       String?
  posterUrl            String?
  backdropUrl          String?
  overview             String?
  directors            String[] @default([])
  cast                 String[] @default([])
  reviewScore          Float?
  reviewSummary        String?
  reviewSource         String?
  moodCalm             Float
  moodDark             Float
  moodEmotional        Float
  moodUplifting        Float
  toneStylish          Float
  toneFunny            Float
  paceFast             Float
  paceSlowBurn         Float
  complexity           Float
  emotionalWeight      Float
  tension              Float
  accessibility        Float
  moodTags             String[]
  watchContexts        String[]
  contentWarnings      String[]
  availabilityNote     String?
  metadata             Json?
  tmdbId               Int?     @unique
  localizedTitles      Json?
  localizedData        Json?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  recommendationResults RecommendationResult[]
  availabilities        MovieAvailability[]
  credits               MovieCredit[]
  swipes                UserMovieSwipe[]
  discoverSwipes        MovieSwipe[]
  watchedByUsers        UserWatchedMovie[]
  watchedContentByUsers UserWatchedContent[]
  watchlistByUsers      UserWatchlistItem[]
  onboardingReactions   OnboardingMovieReaction[]
  quickReactions        QuickReactionLog[]
  watchLogs             WatchLog[]
  likes                 MovieLike[]
  comments              MovieComment[]

  @@unique([title, releaseYear])
  @@index([genrePrimary, releaseYear])
  @@index([runtimeMinutes])
  @@index([reviewScore])
  @@index([directors], type: Gin)
  @@index([cast], type: Gin)
}

model Person {
  id                 String      @id @default(cuid())
  name               String
  normalizedName     String
  tmdbId             Int?        @unique
  profilePath        String?
  biography          String?
  knownForDepartment String?
  metadata           Json?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  credits MovieCredit[]

  @@index([normalizedName])
  @@unique([normalizedName, tmdbId])
}

model MovieCredit {
  id          String     @id @default(cuid())
  movieId      String
  personId     String
  role         PersonRole
  creditOrder  Int?
  character    String?
  job          String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  movie   Movie  @relation(fields: [movieId], references: [id], onDelete: Cascade)
  person  Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@unique([movieId, personId, role])
  @@index([movieId, role, creditOrder])
  @@index([personId, role, creditOrder])
}

model WatchLog {
  id          String   @id @default(cuid())
  userId      String
  movieId     String
  watchedAt   DateTime @default(now())
  score       Float?
  emotion     String?
  memo        String?
  chatSummary String?
  promptUsed  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  movie Movie @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@unique([userId, movieId])
  @@index([userId])
  @@index([movieId])
}

model UserWatchedContent {
  id          String               @id @default(cuid())
  userId      String
  contentType WatchedContentType
  title       String
  posterUrl   String?
  watched     Boolean              @default(true)
  movieId     String?
  source      WatchedContentSource @default(manual)
  catalogSource WatchedCatalogSource @default(manual)
  quickConfidence Int?
  watchSource WatchSource?
  watchedAt   DateTime?
  ratingScore Int?
  reaction    WatchedReaction?
  memo        String?
  rewatch     Boolean              @default(false)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  movie Movie? @relation(fields: [movieId], references: [id], onDelete: SetNull)

  @@unique([userId, movieId, contentType])
  @@index([userId, createdAt(sort: Desc)])
  @@index([contentType, userId])
  @@index([movieId])
}

model QuickReactionLog {
  id           String              @id @default(cuid())
  userId       String
  movieId      String
  shownAt      DateTime
  action       QuickReactionAction
  sessionToken String?
  createdAt    DateTime            @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  movie Movie @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, movieId])
  @@index([sessionToken, createdAt(sort: Desc)])
}

model UserWatchlistItem {
  id                     String          @id @default(cuid())
  userId                 String
  contentType            WatchedContentType
  title                  String
  posterUrl              String?
  movieId                String?
  note                   String?
  priority               Int?
  source                 WatchlistSource @default(manual)
  recommendedFromResultId String?
  savedAt                DateTime        @default(now())
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  movie Movie? @relation(fields: [movieId], references: [id], onDelete: SetNull)

  @@unique([userId, movieId, contentType])
  @@index([userId, savedAt(sort: Desc)])
  @@index([movieId])
}

model MovieAvailability {
  id           String   @id @default(cuid())
  movieId       String
  provider      String
  region        String
  url           String?
  lastSyncedAt  DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  movie Movie @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@unique([movieId, provider, region])
  @@index([provider, region])
  @@index([movieId])
}

model PersonProfileCache {
  id           String     @id @default(cuid())
  name         String
  role         PersonRole
  externalSource String?
  externalPersonId Int?
  matchConfidence Float?
  matchEvidence Json?
  avatarUrl    String?
  bio          String?
  knownFor     String[]   @default([])
  news         Json?
  lastSyncedAt DateTime?
  expiresAt    DateTime
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([name, role])
  @@index([expiresAt])
}

model UserOnboardingProfile {
  id                String   @id @default(cuid())
  userId            String   @unique
  mbtiType          MbtiType?
  selectedMood      UserMood?
  onboardingVersion Int      @default(1)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OnboardingMovieReaction {
  id           String                 @id @default(cuid())
  userId       String
  movieId      String
  reactionType OnboardingReactionType
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  movie Movie @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@unique([userId, movieId])
  @@index([userId, reactionType])
  @@index([movieId])
}

model UserMovieSwipe {
  id         String         @id @default(cuid())
  userId     String
  movieId    String
  knownState MovieKnownState
  swipeAction SwipeAction
  ratingScore Int?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  movie Movie @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([movieId])
}

model UserWatchedMovie {
  id        String        @id @default(cuid())
  userId    String
  movieId   String
  source    WatchedSource
  createdAt DateTime      @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  movie Movie @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@unique([userId, movieId])
  @@index([userId, createdAt(sort: Desc)])
  @@index([movieId])
}

model RecommendationSession {
  id                     String               @id @default(cuid())
  userId                 String
  tasteProfileId         String?
  status                 RecommendationStatus @default(completed)
  currentMoods           String[]
  desiredRuntimeMin      Int
  desiredRuntimeMax      Int
  watchingWith           String
  excludeContentWarnings String[]
  excludeTags            String[]
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt

  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasteProfile UserTasteProfile?    @relation(fields: [tasteProfileId], references: [id], onDelete: SetNull)
  results      RecommendationResult[]
  feedbackLogs FeedbackLog[]

  @@index([userId, createdAt(sort: Desc)])
  @@index([tasteProfileId])
}

model RecommendationResult {
  id                   String   @id @default(cuid())
  sessionId            String
  movieId              String
  rank                 Int
  totalScore           Float
  moodMatchScore       Float
  contextMatchScore    Float
  runtimeFitScore      Float
  styleMatchScore      Float
  knownTasteScore      Float   @default(0)
  currentMoodScore     Float   @default(0)
  mbtiAdjustmentScore  Float   @default(0)
  baseScore            Float   @default(0)
  discoveryScore       Float   @default(0)
  repetitionPenalty    Float   @default(0)
  retrievalSupportScore Float  @default(0)
  retrievalChannels    Json?
  reason1              String
  reason2              String?
  reason3              String?
  createdAt            DateTime @default(now())

  session      RecommendationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  movie        Movie                 @relation(fields: [movieId], references: [id], onDelete: Restrict)
  feedbackLogs FeedbackLog[]

  @@unique([sessionId, rank])
  @@index([sessionId, totalScore(sort: Desc)])
  @@index([movieId])
}

model FeedbackLog {
  id                     String       @id @default(cuid())
  userId                 String
  sessionId              String
  recommendationResultId String?
  reaction               ReactionType
  comment                String?
  createdAt              DateTime     @default(now())

  user                 User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  session              RecommendationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  recommendationResult RecommendationResult? @relation(fields: [recommendationResultId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt(sort: Desc)])
  @@index([sessionId])
  @@index([reaction, createdAt(sort: Desc)])
}

model MovieSwipe {
  id       String   @id @default(cuid())
  userId   String
  movieId  String
  action   String   // "like" | "pass" | "watchlist"
  reasons  String[]
  swipedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  movie Movie @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@unique([userId, movieId])
  @@index([userId])
  @@index([movieId])
}

model UserMovieProfile {
  id               String   @id @default(cuid())
  userId           String   @unique
  totalSwipes      Int      @default(0)
  totalLikes       Int      @default(0)
  genreWeights     Json     @default("{}")
  directorAffinity Json     @default("{}")
  writerAffinity   Json     @default("{}")
  preferSlowPace   Float    @default(0.5)
  preferComplex    Float    @default(0.5)
  preferDark       Float    @default(0.5)
  preferForeign    Float    @default(0.5)
  personalityLabel String?
  personalityUpdatedAt DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MovieLike {
  id        String   @id @default(cuid())
  userId    String
  movieId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  movie Movie @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@unique([userId, movieId])
  @@index([movieId, createdAt(sort: Desc)])
  @@index([userId])
}

model MovieComment {
  id        String   @id @default(cuid())
  userId    String
  movieId   String
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  movie Movie @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@index([movieId, createdAt(sort: Desc)])
  @@index([userId])
}
